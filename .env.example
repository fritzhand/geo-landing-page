# Waitlist provider: "mock" (default), "resend", or "sheets"
# Set in site.config.yaml under waitlist.provider

# Resend (if using resend provider)
RESEND_API_KEY=re_your_api_key_here
RESEND_FROM=hello@yourdomain.com

# Google Sheets (if using sheets provider)
SHEETS_WEBHOOK_URL=https://script.google.com/macros/s/your-script-id/exec
