---
import { loadSiteConfigFromFile } from '@/lib/config';
import type { SiteConfig } from '@/lib/config';
import '@/styles/global.css';

const TEMPLATES = [
  {
    slug: 'saas',
    file: 'site.config.yaml',
    name: 'SaaS',
    type: 'Software',
    description: 'Software product with free & paid pricing tiers. Best for: developer tools, productivity apps, B2B platforms.',
    accent: '#2563EB',
    bgLight: '#EFF6FF',
    isDefault: true,
  },
  {
    slug: 'hardware',
    file: 'templates/hardware.config.yaml',
    name: 'Hardware',
    type: 'Physical Product',
    description: 'Pre-order campaign for a physical product. Best for: consumer hardware, IoT devices, limited-edition items.',
    accent: '#D97706',
    bgLight: '#FEF3C7',
    isDefault: false,
  },
  {
    slug: 'impact',
    file: 'templates/impact.config.yaml',
    name: 'Impact / Nonprofit',
    type: 'Mission-Driven',
    description: 'Mission-driven org with no commercial pricing. Best for: NGOs, nonprofits, open-source projects.',
    accent: '#16A34A',
    bgLight: '#F0FDF4',
    isDefault: false,
  },
  {
    slug: 'biotech',
    file: 'templates/biotech.config.yaml',
    name: 'Biotech',
    type: 'Pre-Commercial Science',
    description: 'Pre-commercial life sciences company seeking investor conversations.',
    accent: '#7C3AED',
    bgLight: '#F5F3FF',
    isDefault: false,
  },
  {
    slug: 'waitlist',
    file: 'templates/waitlist.config.yaml',
    name: 'Waitlist Only',
    type: 'Pre-Launch',
    description: 'Pure email capture for a stealth or pre-launch product. No pricing, no product detail.',
    accent: '#0891B2',
    bgLight: '#ECFEFF',
    isDefault: false,
  },
  {
    slug: 'partnership',
    file: 'templates/partnership.config.yaml',
    name: 'Partnership',
    type: 'B2B · Business Development',
    description: 'Partner and reseller recruitment. Best for: marketplaces, enterprise platforms, channel expansion.',
    accent: '#DB2777',
    bgLight: '#FDF2F8',
    isDefault: false,
  },
] as const;

function getCTALabel(config: SiteConfig): string {
  if (config.contactForm) {
    const t = config.contactForm.type;
    const labels: Record<string, string> = {
      investor: 'Investor Contact',
      partnership: 'Partnership Form',
      collaboration: 'Collaboration Form',
      general: 'Contact Form',
    };
    return labels[t] ?? 'Contact Form';
  }
  if (config.preOrder) return 'Pre-Order';
  if (config.pricing) return 'Pricing Tiers';
  return 'Waitlist';
}

const templates = TEMPLATES.map((t) => {
  const config = loadSiteConfigFromFile(t.file);
  return { ...t, config, ctaLabel: getCTALabel(config) };
});
---

<!DOCTYPE html>
<html lang="en">
<head>
  <script is:inline>
    (function() {
      var t = localStorage.getItem('theme');
      if (t === 'dark' || t === 'light') {
        document.documentElement.classList.add(t);
      }
    })();
  </script>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Template Gallery — Startup Landing Kit</title>
  <meta name="description" content="Six GEO-optimized Astro landing page templates for SaaS, hardware, impact orgs, biotech, waitlist, and partnership. Copy one YAML file and go." />
  <meta property="og:title" content="Template Gallery — Startup Landing Kit" />
  <meta property="og:description" content="Six GEO-optimized Astro landing page templates. Copy one YAML file and go." />
  <meta name="robots" content="index, follow" />
</head>
<body>

  <header class="gallery-header">
    <div class="gallery-container">
      <a href="/" class="header-logo">Startup Landing Kit</a>
      <div class="header-actions">
        <button id="theme-toggle" class="theme-toggle" type="button" aria-label="Toggle dark mode">
          <svg class="icon-sun" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
          <svg class="icon-moon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
        </button>
        <a href="/templates/saas" class="demo-link">See default demo →</a>
      </div>
    </div>
  </header>

  <main>
    <div class="gallery-container">

      <div class="gallery-hero">
        <div class="hero-eyebrow">v2 · 6 Templates</div>
        <h1>Template Gallery</h1>
        <p class="hero-desc">
          Pick the right starting point for your startup type. Each template is a single YAML file —
          copy it, fill in your content, deploy to Vercel.
        </p>
      </div>

      <div class="instructions-bar">
        <div class="instruction-step">
          <span class="step-num">1</span>
          <span>Copy the template YAML</span>
        </div>
        <div class="instruction-divider">→</div>
        <div class="instruction-step">
          <span class="step-num">2</span>
          <span>Edit your content</span>
        </div>
        <div class="instruction-divider">→</div>
        <div class="instruction-step">
          <span class="step-num">3</span>
          <span><code>npm run dev</code> to preview</span>
        </div>
        <div class="instruction-divider">→</div>
        <div class="instruction-step">
          <span class="step-num">4</span>
          <span><code>npx vercel</code> to deploy</span>
        </div>
      </div>

      <div class="templates-grid">
        {templates.map((t) => (
          <article
            class="template-card"
            style={`--accent: ${t.accent}; --accent-bg: ${t.bgLight};`}
          >
            <!-- Visual preview pane -->
            <div class="card-preview">
              <div class="preview-company">{t.config.meta.title}</div>
              <p class="preview-headline">{t.config.hero.headline}</p>
              <p class="preview-sub">{t.config.meta.tagline}</p>
              <div class="preview-cta">{t.config.hero.primaryCta}</div>
            </div>

            <!-- Card body -->
            <div class="card-body">
              <div class="card-title-row">
                <div>
                  <h2 class="card-name">{t.name}</h2>
                  <p class="card-type">{t.type}</p>
                </div>
                <span class="cta-badge">{t.ctaLabel}</span>
              </div>

              <p class="card-desc">{t.description}</p>

              <div class="sections-row">
                <span class="section-chip">Hero</span>
                <span class="section-chip">How It Works</span>
                <span class="section-chip">Features</span>
                {t.config.pricing && <span class="section-chip active">Pricing</span>}
                {t.config.preOrder && <span class="section-chip active">Pre-Order</span>}
                {t.config.contactForm
                  ? <span class="section-chip active">Contact Form</span>
                  : <span class="section-chip active">Waitlist</span>
                }
                <span class="section-chip">FAQ</span>
              </div>

              <div class="card-actions">
                <a href={`/templates/${t.slug}`} class="demo-link-btn">Live Demo →</a>
                <div class="copy-block">
                  {t.isDefault ? (
                    <code class="copy-cmd copy-note"># Default template — already active</code>
                  ) : (
                    <code class="copy-cmd">cp templates/{t.slug}.config.yaml site.config.yaml</code>
                  )}
                </div>
              </div>
            </div>
          </article>
        ))}
      </div>

      <div class="geo-note">
        <div class="geo-note-inner">
          <strong>All templates are GEO-optimized.</strong> Every template includes Schema.org JSON-LD,
          llms.txt, semantic HTML5 landmarks, FAQ microdata, and first-200-word AI citation signals.
          Run <code>npm run geo-check</code> after customizing your content — target score: 80+.
        </div>
      </div>

    </div>
  </main>

  <footer class="gallery-footer">
    <div class="gallery-container footer-inner">
      <span>Startup Landing Kit</span>
      <a href="/">← Back to gallery</a>
    </div>
  </footer>

</body>
</html>

<style>
  /* Layout */
  .gallery-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header */
  .gallery-header {
    border-bottom: 1px solid var(--color-border);
    padding: 16px 0;
    position: sticky;
    top: 0;
    background-color: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(12px);
    z-index: 10;
  }

  @media (prefers-color-scheme: dark) {
    .gallery-header {
      background-color: rgba(9, 9, 11, 0.9);
    }
  }

  html.dark .gallery-header {
    background-color: rgba(9, 9, 11, 0.9);
  }

  html.light .gallery-header {
    background-color: rgba(255, 255, 255, 0.9);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 16px;
  }

  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background: transparent;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: color 150ms ease, border-color 150ms ease;
  }

  .theme-toggle:hover {
    color: var(--color-text);
    border-color: var(--color-text-muted);
  }

  .icon-sun { display: none; }
  .icon-moon { display: block; }

  @media (prefers-color-scheme: dark) {
    .icon-sun { display: block; }
    .icon-moon { display: none; }
  }

  html.dark .icon-sun { display: block; }
  html.dark .icon-moon { display: none; }
  html.light .icon-sun { display: none; }
  html.light .icon-moon { display: block; }

  .gallery-header .gallery-container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .header-logo {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 800;
    color: var(--color-text);
    text-decoration: none;
    letter-spacing: -0.02em;
  }

  .demo-link {
    font-size: 14px;
    font-weight: 500;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 150ms ease;
  }

  .demo-link:hover {
    color: var(--color-primary);
  }

  /* Gallery hero */
  .gallery-hero {
    padding: 72px 0 48px;
    max-width: 640px;
  }

  .hero-eyebrow {
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-primary);
    margin-bottom: 12px;
  }

  .gallery-hero h1 {
    font-size: 56px;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 16px;
  }

  .hero-desc {
    font-size: 18px;
    color: var(--color-text-muted);
    line-height: 1.6;
    max-width: 520px;
  }

  /* Instructions bar */
  .instructions-bar {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    padding: 16px 24px;
    background-color: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    margin-bottom: 56px;
    font-size: 14px;
  }

  .instruction-step {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--color-text);
  }

  .instruction-step code {
    font-family: var(--font-mono);
    font-size: 13px;
    background-color: var(--color-surface-alt);
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--color-text);
  }

  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    background-color: var(--color-primary);
    color: #ffffff;
    font-size: 11px;
    font-weight: 700;
    flex-shrink: 0;
  }

  .instruction-divider {
    color: var(--color-border);
    font-size: 16px;
    flex-shrink: 0;
  }

  /* Templates grid */
  .templates-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
    margin-bottom: 64px;
  }

  /* Template card */
  .template-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: var(--color-background);
    transition: transform 150ms ease, box-shadow 150ms ease;
    display: flex;
    flex-direction: column;
  }

  .template-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
  }

  /* Preview pane */
  .card-preview {
    padding: 28px 24px;
    background-color: var(--accent-bg);
    border-bottom: 1px solid var(--color-border);
    display: flex;
    flex-direction: column;
    gap: 8px;
    min-height: 160px;
  }

  .preview-company {
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
  }

  .preview-headline {
    font-family: var(--font-heading);
    font-size: 18px;
    font-weight: 800;
    color: #0A0A0B;
    line-height: 1.2;
    letter-spacing: -0.02em;
    margin: 0;
    /* Clamp to 3 lines */
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .preview-sub {
    font-size: 12px;
    color: #71717A;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 1;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .preview-cta {
    display: inline-flex;
    align-self: flex-start;
    font-size: 12px;
    font-weight: 600;
    padding: 6px 14px;
    border-radius: var(--radius-md);
    background-color: var(--accent);
    color: #ffffff;
    margin-top: 4px;
    white-space: nowrap;
  }

  /* Card body */
  .card-body {
    padding: 20px 24px 24px;
    display: flex;
    flex-direction: column;
    gap: 14px;
    flex: 1;
  }

  .card-title-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 8px;
  }

  .card-name {
    font-size: 17px;
    font-weight: 700;
    margin: 0;
    line-height: 1.2;
  }

  .card-type {
    font-size: 12px;
    color: var(--color-text-muted);
    margin: 2px 0 0;
  }

  .cta-badge {
    flex-shrink: 0;
    font-size: 11px;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    background-color: var(--accent-bg);
    color: var(--accent);
    border: 1px solid var(--accent);
    white-space: nowrap;
  }

  .card-desc {
    font-size: 13px;
    color: var(--color-text-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Sections row */
  .sections-row {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
  }

  .section-chip {
    font-size: 11px;
    font-weight: 500;
    padding: 3px 8px;
    border-radius: var(--radius-sm);
    background-color: var(--color-surface);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
  }

  .section-chip.active {
    background-color: var(--accent-bg);
    color: var(--accent);
    border-color: var(--accent);
    font-weight: 600;
  }

  /* Card actions */
  .card-actions {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .demo-link-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 20px;
    font-size: 14px;
    font-weight: 600;
    color: var(--accent);
    border: 1px solid var(--accent);
    border-radius: var(--radius-md);
    text-decoration: none;
    transition: background-color 150ms ease, color 150ms ease;
  }

  .demo-link-btn:hover {
    background-color: var(--accent);
    color: #ffffff;
  }

  /* Copy block */
  .copy-block {
    padding-top: 12px;
    border-top: 1px solid var(--color-border);
  }

  .copy-cmd {
    display: block;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--color-text-muted);
    word-break: break-all;
  }

  .copy-note {
    color: var(--color-text-muted);
    font-style: italic;
  }

  /* GEO note */
  .geo-note {
    margin-bottom: 64px;
  }

  .geo-note-inner {
    padding: 16px 24px;
    background-color: var(--color-surface-alt);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.6;
  }

  .geo-note-inner strong {
    color: var(--color-text);
  }

  .geo-note-inner code {
    font-family: var(--font-mono);
    font-size: 12px;
    background-color: var(--color-surface);
    padding: 1px 5px;
    border-radius: 3px;
  }

  /* Footer */
  .gallery-footer {
    border-top: 1px solid var(--color-border);
    padding: 24px 0;
  }

  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 14px;
    color: var(--color-text-muted);
  }

  .footer-inner a {
    color: var(--color-text-muted);
    text-decoration: none;
  }

  .footer-inner a:hover {
    color: var(--color-primary);
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .templates-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 767px) {
    .gallery-hero h1 {
      font-size: 36px;
    }

    .instructions-bar {
      gap: 12px;
    }

    .instruction-divider {
      display: none;
    }

    .templates-grid {
      grid-template-columns: 1fr;
    }

    .footer-inner {
      flex-direction: column;
      gap: 8px;
      text-align: center;
    }
  }
</style>

<script is:inline>
  document.getElementById('theme-toggle')?.addEventListener('click', function() {
    var html = document.documentElement;
    var isDark = html.classList.contains('dark') ||
      (!html.classList.contains('light') && window.matchMedia('(prefers-color-scheme: dark)').matches);

    if (isDark) {
      html.classList.remove('dark');
      html.classList.add('light');
      localStorage.setItem('theme', 'light');
    } else {
      html.classList.remove('light');
      html.classList.add('dark');
      localStorage.setItem('theme', 'dark');
    }
  });
</script>
