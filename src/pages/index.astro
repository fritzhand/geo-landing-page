---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Header from '@/components/Header.astro';
import Hero from '@/components/Hero.astro';
import SocialProof from '@/components/SocialProof.astro';
import ProductExplanation from '@/components/ProductExplanation.astro';
import HowItWorks from '@/components/HowItWorks.astro';
import ValueBenefits from '@/components/ValueBenefits.astro';
import Pricing from '@/components/Pricing.astro';
import FAQ from '@/components/FAQ.astro';
import FinalCTA from '@/components/FinalCTA.astro';
import WaitlistForm from '@/components/WaitlistForm.astro';
import Footer from '@/components/Footer.astro';
---

<BaseLayout>
  <Header />
  <main>
    <Hero />
    <SocialProof />
    <ProductExplanation />
    <HowItWorks />
    <ValueBenefits />
    <Pricing />
    <FAQ />
    <FinalCTA />
    <section aria-label="Join Waitlist" class="section" id="waitlist-section">
      <div class="container">
        <WaitlistForm />
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
