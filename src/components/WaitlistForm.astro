---
import { getSiteConfig } from '@/lib/config';
const { hero } = getSiteConfig();
---

<!-- Progressive enhancement: works without JS via form POST to API route -->
<form
  id="waitlist"
  class="waitlist-form"
  method="POST"
  action="/api/waitlist"
  data-enhanced="false"
>
  <div class="form-row">
    <label for="email" class="sr-only">Email address</label>
    <input
      type="email"
      id="email"
      name="email"
      placeholder="you@startup.com"
      required
      autocomplete="email"
      class="form-input"
    />
    <!-- Honeypot for spam prevention -->
    <input type="text" name="company_url" class="hp-field" tabindex="-1" autocomplete="off" aria-hidden="true" />
    <button type="submit" class="btn btn-primary form-btn">
      {hero.primaryCta}
    </button>
  </div>
  <div class="form-message" aria-live="polite"></div>
</form>

<style>
  .waitlist-form {
    max-width: 480px;
  }

  .form-row {
    display: flex;
    gap: 8px;
  }

  .form-input {
    flex: 1;
    font-family: var(--font-body);
    font-size: 16px;
    padding: 14px 20px;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    background-color: var(--color-background);
    color: var(--color-text);
    outline: none;
    transition: border-color var(--duration-short) ease;
  }

  .form-input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.1);
  }

  .form-input::placeholder {
    color: var(--color-text-muted);
  }

  .form-btn {
    flex-shrink: 0;
  }

  .hp-field {
    position: absolute;
    left: -9999px;
    opacity: 0;
    height: 0;
    width: 0;
    overflow: hidden;
  }

  .form-message {
    margin-top: 12px;
    font-size: 14px;
    min-height: 20px;
  }

  .form-message.success {
    color: var(--color-success);
  }

  .form-message.error {
    color: var(--color-error);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 480px) {
    .form-row {
      flex-direction: column;
    }
  }
</style>

<script>
  const form = document.getElementById('waitlist') as HTMLFormElement;
  if (form) {
    form.dataset.enhanced = 'true';
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const msgEl = form.querySelector('.form-message') as HTMLElement;
      const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
      const emailInput = form.querySelector('input[type="email"]') as HTMLInputElement;

      if (!emailInput.value || !emailInput.validity.valid) {
        msgEl.textContent = 'Please enter a valid email address.';
        msgEl.className = 'form-message error';
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Submitting…';
      msgEl.textContent = '';
      msgEl.className = 'form-message';

      try {
        const formData = new FormData(form);
        const res = await fetch('/api/waitlist', {
          method: 'POST',
          body: formData,
        });

        const data = await res.json();

        if (data.success) {
          msgEl.textContent = 'Thanks! We\'ll be in touch.';
          msgEl.className = 'form-message success';
          emailInput.value = '';
        } else {
          msgEl.textContent = data.error || 'Something went wrong. Please try again.';
          msgEl.className = 'form-message error';
        }
      } catch {
        msgEl.textContent = 'Network error. Please try again.';
        msgEl.className = 'form-message error';
      } finally {
        btn.disabled = false;
        btn.textContent = form.dataset.ctaText || 'Join Waitlist';
      }
    });
  }
</script>
